# Supabase project URL — found in Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — found in Supabase dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — found in Supabase dashboard > Project Settings > API (keep secret, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Groq API key — create one at https://console.groq.com — must also be set in Vercel dashboard > Settings > Environment Variables
GROQ_API_KEY=

# Email address to assign demo companies to when running: pnpm seed (not used at runtime)
SEED_KAM_EMAIL=
