# --- Supabase (public, used by browser + server clients) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Service role key (server-only; used ONLY by scripts/seed.ts) ---
# Never expose this to the browser. Do not import it in app code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Seed configuration ---
# The Google account email an evaluator will sign in with.
# The seed assigns one KAM this email so that account owns a real portfolio on first login.
SEED_KAM_EMAIL=evaluator@example.com

# Set to "true" to allow scripts/seed.ts to wipe + reseed existing data.
SEED_RESET=false

# --- AI (Anthropic) ---
# Used by POST /api/health-scores/generate to call Claude Haiku.
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
